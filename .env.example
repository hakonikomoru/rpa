# =============================================================================
# rpa ローカル設定（コピー: cp .env.example .env）
# 実値は .env にのみ記載。Git にコミットしないこと。
# =============================================================================

# --- Amazon 一般（セール ASIN 収集・ログイン） ---
AMAZON_EMAIL=
AMAZON_PASSWORD=
AMAZON_AFFILIATE_ID=premierter0ad-22
# 0 = セール一覧を最後まで（次ページ・スクロール）
AMAZON_DEALS_PAGES=0
AMAZON_DEALS_ALL=1
AMAZON_SKIP_LOGIN=1
AMAZON_MAX_PAGES_PER_SEED=40
AMAZON_MAX_SEEDS=80
# AMAZON_SALE_SEED_URLS=https://example.com/...
# AMAZON_POST_TWEETS=1
# CHROME_HEADLESS=1

# --- Amazon セラーセントラル（itemAddSearchFromJP / US） ---
AMAZON_SELLER_CENTRAL_JP_EMAIL=
AMAZON_SELLER_CENTRAL_JP_PASSWORD=
AMAZON_SELLER_CENTRAL_US_EMAIL=
AMAZON_SELLER_CENTRAL_US_PASSWORD=

# --- Twitter API（Amazon ツイート: config.py の TWITTER_* = premier_teru 想定） ---
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# --- Twitter API（箱荷こもる / TwitterFollow.py 用） ---
TWITTER_HAKONIKOMORU_API_KEY=
TWITTER_HAKONIKOMORU_API_SECRET=
TWITTER_HAKONIKOMORU_ACCESS_TOKEN=
TWITTER_HAKONIKOMORU_ACCESS_TOKEN_SECRET=

# --- Twitter ブラウザログイン（Selenium 系スクリプト） ---
TWITTER_BROWSER_USERNAME_KEN=
TWITTER_BROWSER_PASSWORD_KEN=
TWITTER_BROWSER_USERNAME_PREMIER=
TWITTER_BROWSER_PASSWORD_PREMIER=

# --- メルカリ（Google ログイン） ---
MERCARI_GOOGLE_EMAIL=
MERCARI_GOOGLE_PASSWORD=
# MERCARI_SHOPS_EMAIL=
# MERCARI_SHOPS_PASSWORD=

# --- 楽天 e-NAVI ---
RAKUTEN_ENAVI_USER=
RAKUTEN_ENAVI_PASSWORD=

# --- 東京カレンダーデート（Facebook ログイン） ---
TOKYO_CALENDAR_EMAIL=
TOKYO_CALENDAR_PASSWORD=

# --- OpenAI（ChatGPT.py） ---
OPENAI_API_KEY=

# --- Bitly（カンマ区切り。複数トークンをローテーション） ---
BITLY_ACCESS_TOKENS=

# --- パス（通常は変更不要） ---
# RPA_REPO_ROOT=/Users/ebata/app/rpa
# RPA_OUTPUT_DIR=/Users/ebata/app/rpa/PythonRpa/outPutFile
